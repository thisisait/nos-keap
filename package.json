{
  "name": "keap",
  "private": true,
  "version": "1.9.2",
  "type": "module",
  "description": "Knowledge Explorer and Preserver — curated knowledge taxonomy with content links into nOS services, for humans and nOS agents.",
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"vite\" \"npm run dev:api\"",
    "dev:web": "vite",
    "dev:api": "PORT=8081 tsx watch server/index.ts",
    "dev:ext": "wxt",
    "dev:ext:firefox": "wxt -b firefox",
    "build": "vite build && npm run build:server && npm run build:ext",
    "build:ext": "wxt build",
    "build:ext:firefox": "wxt build -b firefox",
    "build:ext:safari": "wxt build -b safari",
    "build:ext:safari-mv3": "wxt build -b safari --mv3",
    "package:safari": "npm run build:ext:safari-mv3 && xcrun safari-web-extension-converter --app-name KEAP --bundle-identifier eu.pazny.keap --macos-only --no-prompt --no-open --force dist-extension/safari-mv3",
    "build:server": "tsc -p tsconfig.server.json && esbuild server/index.ts --bundle --platform=node --format=esm --packages=external --outfile=dist-server/index.js",
    "build:dev": "vite build --mode development",
    "zip:ext": "wxt zip",
    "zip:ext:firefox": "wxt zip -b firefox",
    "wxt:prepare": "wxt prepare",
    "postinstall": "wxt prepare",
    "start": "node dist-server/index.js",
    "lint": "eslint .",
    "knowledge:lint": "node knowledge/lint.mjs",
    "knowledge:roundtrip": "node knowledge/roundtrip.mjs",
    "knowledge:dry-run": "node knowledge/ingest.mjs --dry-run --canonical knowledge/canonical",
    "knowledge:xrefs": "node knowledge/lift-xrefs.mjs",
    "preview": "vite preview",
    "test:e2e": "playwright test"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-alert-dialog": "^1.1.1",
    "@radix-ui/react-aspect-ratio": "^1.1.0",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-checkbox": "^1.1.1",
    "@radix-ui/react-collapsible": "^1.1.0",
    "@radix-ui/react-context-menu": "^2.2.1",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-hover-card": "^1.1.1",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-menubar": "^1.1.1",
    "@radix-ui/react-navigation-menu": "^1.2.0",
    "@radix-ui/react-popover": "^1.1.1",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-radio-group": "^1.2.0",
    "@radix-ui/react-scroll-area": "^1.1.0",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slider": "^1.2.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.1",
    "@radix-ui/react-toggle": "^1.1.0",
    "@radix-ui/react-toggle-group": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.4",
    "@tanstack/react-query": "^5.56.2",
    "@tanstack/react-table": "^8.21.3",
    "aws4fetch": "^1.0.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "d3-force-3d": "^3.0.6",
    "date-fns": "^3.6.0",
    "embla-carousel-react": "^8.3.0",
    "express": "^4.21.0",
    "fflate": "^0.8.3",
    "helmet": "^8.0.0",
    "i18next": "^26.3.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "input-otp": "^1.2.4",
    "libsql": "^0.5.29",
    "lucide-react": "^0.462.0",
    "next-themes": "^0.3.0",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-force-graph-3d": "^1.29.1",
    "react-hook-form": "^7.53.0",
    "react-i18next": "^17.0.9",
    "react-resizable-panels": "^2.1.3",
    "react-router-dom": "^6.26.2",
    "react-select": "^5.10.1",
    "recharts": "^2.12.7",
    "sonner": "^1.5.0",
    "tailwind-merge": "^2.5.2",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.185.1",
    "three-spritetext": "^1.10.0",
    "vaul": "^0.9.3",
    "yaml": "^2.9.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/typography": "^0.5.15",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.9.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "globals": "^15.9.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.11",
    "tsx": "^4.19.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.0.1",
    "vite": "^5.4.1",
    "vitest": "^4.1.9",
    "wxt": "0.19.29"
  }
}
